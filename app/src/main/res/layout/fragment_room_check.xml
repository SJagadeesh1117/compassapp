<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.2"
            android:text="ROOM DIRECTION CHECKER"
            android:textColor="#E94560"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Select room  •  Point phone  •  Check Vastu"
            android:textColor="#6C7086"
            android:textSize="11sp" />

        <!-- Room selector chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none"
            android:paddingHorizontal="16dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRooms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp" />

        </HorizontalScrollView>

        <!-- Mini compass -->
        <com.compass.app.CompassView
            android:id="@+id/compassViewRoom"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="12dp" />

        <!-- Direction Names Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/direction_card_bg"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="ENG" android:textColor="#6C7086" android:textSize="10sp"
                    android:letterSpacing="0.1" android:fontFamily="sans-serif-condensed" />
                <TextView android:id="@+id/tvRoomEnglish" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="North" android:textColor="#CDD6F4" android:textSize="20sp"
                    android:fontFamily="sans-serif-medium" android:textAlignment="textEnd" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#20CDD6F4" android:layout_marginVertical="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="TEL" android:textColor="#6C7086" android:textSize="10sp"
                    android:letterSpacing="0.1" android:fontFamily="sans-serif-condensed" />
                <TextView android:id="@+id/tvRoomTelugu" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Uttaram" android:textColor="#F38BA8" android:textSize="20sp"
                    android:fontFamily="sans-serif-medium" android:textAlignment="textEnd" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#20CDD6F4" android:layout_marginVertical="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="TAM" android:textColor="#6C7086" android:textSize="10sp"
                    android:letterSpacing="0.1" android:fontFamily="sans-serif-condensed" />
                <TextView android:id="@+id/tvRoomTamil" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Vadakku" android:textColor="#CBA6F7" android:textSize="20sp"
                    android:fontFamily="sans-serif-medium" android:textAlignment="textEnd" />
            </LinearLayout>
        </LinearLayout>

        <!-- Vastu Result Card -->
        <LinearLayout
            android:id="@+id/cardRoomVastu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/vastu_rating_bg"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp">

            <TextView android:id="@+id/tvRoomVastuHeader"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="MAIN ENTRANCE VASTU"
                android:textColor="#6C7086" android:textSize="10sp"
                android:letterSpacing="0.15" android:fontFamily="sans-serif-condensed" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                <TextView android:id="@+id/tvRoomVastuStars"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="★★★★★" android:textColor="#A6E3A1" android:textSize="18sp" />
                <TextView android:id="@+id/tvRoomVastuLabel"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="  EXCELLENT" android:textColor="#A6E3A1" android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed" android:textStyle="bold" />
            </LinearLayout>

            <TextView android:id="@+id/tvRoomVastuAdvice"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Ideal direction for this room."
                android:textColor="#9399B2" android:textSize="12sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Point phone toward the selected room's wall or window"
            android:textAlignment="center"
            android:textColor="#45475A"
            android:textSize="11sp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>
</ScrollView>
